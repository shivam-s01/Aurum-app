<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aurum.music">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <uses-permission android:name="android.permission.USE_FINGERPRINT"/>
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <!-- Foreground service + wake lock for background audio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Notification permission (Android 13+ requires explicit request) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Local music: Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO"/>
    <!-- Local music: Android 12 and below -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <application
        android:label="Aurum Music"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:enableOnBackInvokedCallback="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme"/>

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Native Media3 MediaSessionService — replaces audio_service's
             AudioService entirely. Owns the MediaSession, foreground
             notification, and lock-screen/Bluetooth/Android Auto controls
             directly from AurumAudioEngine's ExoPlayer instance. The
             MediaSessionService action intent-filter is what lets the
             system (and MediaController.Builder on the Dart/other-process
             side, if ever needed) discover and bind to this service. -->
        <service
            android:name=".AurumMediaSessionService"
            android:foregroundServiceType="mediaPlayback"
            android:exported="true"
            android:stopWithTask="false">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService"/>
                <action android:name="android.media.browse.MediaBrowserService"/>
            </intent-filter>
        </service>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2"/>
        <!-- PERF FIX (the "very laggy for ~1 min on open, then buttery
             smooth" symptom): with the old Skia rendering backend, every
             GPU shader (blur, gradient, rounded-clip, shadow, etc.) is
             compiled lazily, on the GPU thread, the FIRST time it's
             actually painted. Aurum's home screen paints ~5-6 different
             blur/gradient/shadow combos within its first few frames (nav
             bar glass blur, mini player blur, hero card gradients, card
             shadows, artwork rounded-clips) — each one independently
             stalls the GPU thread for tens to hundreds of ms the first
             time it's hit, which reads exactly as "laggy at open, smooth
             after". Once every distinct shader combo has been hit once
             (usually within the first minute of normal scrolling/
             navigation), nothing new needs compiling and it's smooth.
             Impeller precompiles its (much smaller, fixed) shader set
             ahead of time instead of compiling on first paint, which
             eliminates this whole class of jank. Available/stable for
             Android since Flutter 3.24+. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="true"/>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- Home-screen widgets — compact "now playing" strip and the
             full version with prev/play-pause/next controls. Both read
             directly from AurumMediaSessionService.sharedEngine's
             ExoPlayer and respond to their own button taps via broadcast
             intents, so they keep working even without the Flutter
             engine/Activity running, same as the lock-screen notification
             already does. See AurumWidgetProvider.kt. -->
        <receiver
            android:name=".AurumWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
                <action android:name="com.aurum.music.widget.ACTION_PLAY_PAUSE"/>
                <action android:name="com.aurum.music.widget.ACTION_NEXT"/>
                <action android:name="com.aurum.music.widget.ACTION_PREV"/>
                <action android:name="com.aurum.music.widget.ACTION_REFRESH"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_compact_info"/>
        </receiver>

        <receiver
            android:name=".AurumWidgetProviderFull"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_full_info"/>
        </receiver>
    </application>
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
    </queries>
</manifest>
