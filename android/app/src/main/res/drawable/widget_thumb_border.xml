<?xml version="1.0" encoding="utf-8"?>
<!--
  Thin border sitting behind the artwork thumbnail, giving it a subtle
  "elevated" edge even without a real drop shadow (RemoteViews has no
  elevation/shadow support). Purely static, no bitmap.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1F1F2E"/>
    <corners android:radius="14dp"/>
</shape>
