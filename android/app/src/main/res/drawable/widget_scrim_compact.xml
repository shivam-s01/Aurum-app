<?xml version="1.0" encoding="utf-8"?>
<!--
  Legibility scrim for the compact widget — same top-transparent,
  bottom-dark gradient language as the in-app hero card's scrim, just
  applied left-to-right here since the compact layout is a short wide
  strip rather than a tall card. Darkest behind the text/button side.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#4D000000"
        android:centerColor="#66000000"
        android:endColor="#B3000000"/>
</shape>
