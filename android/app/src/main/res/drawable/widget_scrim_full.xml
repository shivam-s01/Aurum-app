<?xml version="1.0" encoding="utf-8"?>
<!--
  Legibility scrim for the full widget — top-to-bottom, same gradient
  direction and feel as the in-app hero "now playing stage" scrim
  (transparent at top, dark at bottom where text/controls sit).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="90"
        android:startColor="#26000000"
        android:centerColor="#66000000"
        android:endColor="#CC000000"/>
</shape>
