<?xml version="1.0" encoding="utf-8"?>
<!--
  FIX: this file was only whitelisting "aurum-stream.sharmashivam9109.workers.dev",
  a domain that doesn't match either Cloudflare Worker actually in use
  (aurum-worker.shivamsharma962122.workers.dev and
  aurumsic.shivamsharma962122.workers.dev). Android's network security
  policy silently blocks ALL traffic to domains not explicitly listed here
  when usesCleartextTraffic="false" + a custom networkSecurityConfig is set
  — this is almost certainly why the Worker call failed in diagnostics
  ("1. Cloudflare Worker ❌ FAILED") and very likely contributed to the
  ExoPlayer "Source error" too, since some Android versions surface a
  blocked/refused connection as a generic source error rather than a
  clear security-exception message.

  Now whitelisting:
    - *.workers.dev (covers BOTH worker subdomains used by this app, and
      any future worker renames, without needing to edit this file again)
    - saavncdn.com (the actual JioSaavn audio CDN — confirmed working via
      curl: 200 OK, Content-Type: audio/mp4)
    - jiosaavn.com (used by some direct-fallback API calls in api_service.dart)
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>

    <!-- just_audio (Android) spins up a local loopback HTTP proxy on
         127.0.0.1 whenever AudioSource.uri is given a `headers:` map, or
         when using LockCachingAudioSource / StreamAudioSource. That proxy
         talks plain HTTP to itself within the device — cleartext must be
         allowed for localhost or the player silently fails with a generic
         ExoPlayer "Source error" (code=0) at position 0ms. We no longer
         pass headers (see audio_handler.dart), but this stays as a safety
         net for any future use of those APIs. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">workers.dev</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">saavncdn.com</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">jiosaavn.com</domain>
    </domain-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">onrender.com</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">akamaized.net</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">akamaihd.net</domain>
    </domain-config>

    <!-- FIX: YouTube fallback chain (_ytStreamById) was failing on EVERY
         stage — Piped, Invidious, and youtube_explode_dart — because none
         of their domains were whitelisted here. With cleartextTrafficPermitted
         ="false" + a custom networkSecurityConfig, Android blocks ALL
         outbound traffic to non-listed domains, so every fallback stage's
         HTTP request was killed before it left the device. This is the
         exact same class of bug as the earlier Worker/CDN block — just on
         a different set of domains. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">kavin.rocks</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">privacy.com.de</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">projectsegfau.lt</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">invidious.io.lol</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">nadeko.net</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">privacydev.net</domain>
    </domain-config>

    <!-- youtube_explode_dart (last-resort stage) needs youtube.com itself
         for search/manifest calls, AND googlevideo.com — the actual CDN
         domain that resolved audio stream URLs point to (this is what
         ExoPlayer connects to AFTER resolution succeeds, regardless of
         which fallback stage resolved it). Missing this would make the
         resolve step succeed but playback fail right after, with the
         same idle@0ms symptom as before. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">youtube.com</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">googlevideo.com</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">ytimg.com</domain>
    </domain-config>
</network-security-config>
