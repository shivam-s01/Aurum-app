<?xml version="1.0" encoding="utf-8"?>
<!--
  Full Aurum widget metadata. Sized around a 4x2 cell (matching the
  "Airtel UPI"-style large tile shown in the OS widget picker screenshot)
  so it comfortably fits the bigger artwork + full prev/play/next
  transport row.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:minResizeWidth="180dp"
    android:minResizeHeight="90dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_full"
    android:previewLayout="@layout/widget_full"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_full_description"/>
