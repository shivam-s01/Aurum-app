<?xml version="1.0" encoding="utf-8"?>
<!--
  Full Aurum widget (target ~4x2 cells) — artwork/bitmap rendering
  permanently removed (see AurumWidgetProvider.kt header comment).
  Flat gradient card, larger title/artist, and a full prev/play/next
  transport row. No ImageView here ever receives a runtime bitmap.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_gradient_card"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="4dp"
            android:layout_height="56dp"
            android:background="@drawable/widget_accent_bar"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#B3FFFFFF"
                android:textSize="12.5sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_widget_prev"/>

                <ImageView
                    android:id="@+id/widget_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:padding="8dp"
                    android:background="@drawable/widget_circle_button"
                    android:src="@drawable/ic_widget_play"/>

                <ImageView
                    android:id="@+id/widget_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_widget_next"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
