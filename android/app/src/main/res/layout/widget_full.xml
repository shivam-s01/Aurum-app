<?xml version="1.0" encoding="utf-8"?>
<!--
  Full Aurum widget (target ~4x2 cells) — premium/Spotify-tier redesign.
  Larger hero artwork, near-black card, prominent play/pause circle as
  the visual anchor, minimal low-opacity prev/next, and a thin static
  progress rail for visual richness. Still no bare <View> tags and no
  background/blur bitmap — only the one small artwork thumbnail
  bitmap, everything else is static drawable resources.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_gradient_card"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <!-- Hero artwork — larger, elevated card-on-card feel via the
             widget_thumb_mask placeholder + a hairline border drawable
             layered underneath it. -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_thumb_border"/>

            <ImageView
                android:id="@+id/widget_artwork_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="1.5dp"
                android:scaleType="centerCrop"
                android:background="@drawable/widget_thumb_mask"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="16.5sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="3dp"/>

            <!-- Thin static progress rail — purely decorative (no live
                 seek position is tracked here), but it's the single
                 detail that reads most as "real music app" rather than
                 "notification card". -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/widget_progress_track">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="3dp"
                    android:background="@drawable/widget_progress_fill"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_prev"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:padding="6dp"
                    android:alpha="0.75"
                    android:src="@drawable/ic_widget_prev"/>

                <ImageView
                    android:id="@+id/widget_play_pause"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="10dp"
                    android:padding="12dp"
                    android:background="@drawable/widget_circle_button"
                    android:src="@drawable/ic_widget_play"/>

                <ImageView
                    android:id="@+id/widget_next"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="10dp"
                    android:padding="6dp"
                    android:alpha="0.75"
                    android:src="@drawable/ic_widget_next"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
