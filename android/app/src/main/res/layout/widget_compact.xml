<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact Aurum widget (target ~2x2 cells), Arc Player-style flat card:
  solid dark card background (no artwork bleed — keeps it calm/legible
  at small size), square rounded artwork thumb on the left, title/artist
  stacked in the middle, and a compact prev/play/next pill row.
  Tapping the artwork or text opens the app; each transport control has
  its own tap target.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Flat card background — solid, not the blurred artwork bleed
         used previously. widget_bg_image is kept (still set at runtime)
         but now sits fully behind the card fill + is heavily scrimmed,
         so it only ever contributes a faint tint rather than a busy
         photo background. -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_background_fallback"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_flat_card"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="10dp">

        <ImageView
            android:id="@+id/widget_artwork_thumb"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_thumb_mask"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <!-- Compact transport pill: prev / play-pause / next, matching
             the reference Arc Player row layout instead of a single
             play/pause circle. -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_pill_bg"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <ImageView
                android:id="@+id/widget_prev"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:padding="5dp"
                android:src="@drawable/ic_widget_prev"/>

            <ImageView
                android:id="@+id/widget_play_pause"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="2dp"
                android:padding="6dp"
                android:background="@drawable/widget_circle_button"
                android:src="@drawable/ic_widget_play"/>

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="2dp"
                android:padding="5dp"
                android:src="@drawable/ic_widget_next"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
