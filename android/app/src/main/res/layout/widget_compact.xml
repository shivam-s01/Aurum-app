<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact Aurum widget (target ~2x2 / 4x1 cells). Shows the blurred-
  artwork background (set at runtime via setImageViewBitmap on
  widget_bg_image), current track title/artist, and a single play/pause
  button. Tapping the artwork thumbnail or the text opens the app
  straight to the full player; only the play/pause circle has its own
  narrower tap target so a stray tap on the card doesn't accidentally
  toggle playback when the user meant to open the app.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Blurred artwork background, or widget_background_fallback while
         nothing has loaded yet / no song is playing. -->
    <ImageView
        android:id="@+id/widget_bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/widget_background_fallback"/>

    <!-- Dark scrim over the blur for text legibility, same gradient
         language as the in-app hero card. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_scrim_compact"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="12dp">

        <ImageView
            android:id="@+id/widget_artwork_thumb"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_thumb_mask"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#B3FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="6dp"
            android:padding="6dp"
            android:background="@drawable/widget_circle_button"
            android:src="@drawable/ic_widget_play"/>
    </LinearLayout>
</FrameLayout>
