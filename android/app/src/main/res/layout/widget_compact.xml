<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact Aurum widget (target ~2x2 cells) — premium redesign, same
  principles as widget_full.xml at a smaller scale: bordered artwork,
  prominent play/pause, minimal prev/next. No bare <View> tags, no
  background/blur bitmap.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_gradient_card"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="10dp">

        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_thumb_border"/>

            <ImageView
                android:id="@+id/widget_artwork_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="1.5dp"
                android:scaleType="centerCrop"
                android:background="@drawable/widget_thumb_mask"/>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/widget_prev"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="5dp"
                android:alpha="0.75"
                android:src="@drawable/ic_widget_prev"/>

            <ImageView
                android:id="@+id/widget_play_pause"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="2dp"
                android:padding="8dp"
                android:background="@drawable/widget_circle_button"
                android:src="@drawable/ic_widget_play"/>

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="2dp"
                android:padding="5dp"
                android:alpha="0.75"
                android:src="@drawable/ic_widget_next"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
