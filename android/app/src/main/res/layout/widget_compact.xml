<?xml version="1.0" encoding="utf-8"?>
<!--
  Compact Aurum widget — artwork/bitmap rendering permanently removed
  (see AurumWidgetProvider.kt header comment). Flat gradient card,
  title/artist, and a prev/play/next control pill. No ImageView ever
  receives a runtime bitmap here — only static drawable resources.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_gradient_card"/>

    <LinearLayout
        android:id="@+id/widget_root_tap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="10dp">

        <View
            android:layout_width="4dp"
            android:layout_height="34dp"
            android:background="@drawable/widget_accent_bar"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aurum"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap to play something"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="1dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/widget_pill_bg"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp">

            <ImageView
                android:id="@+id/widget_prev"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:padding="5dp"
                android:src="@drawable/ic_widget_prev"/>

            <ImageView
                android:id="@+id/widget_play_pause"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="2dp"
                android:padding="6dp"
                android:background="@drawable/widget_circle_button"
                android:src="@drawable/ic_widget_play"/>

            <ImageView
                android:id="@+id/widget_next"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="2dp"
                android:padding="5dp"
                android:src="@drawable/ic_widget_next"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
