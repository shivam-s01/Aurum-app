<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) shows a system splash screen by default,
         using a WHITE background, even without any installSplashScreen()
         call in code — this theme override is what actually controls
         that, independent of MainActivity.

         We deliberately set ONLY windowSplashScreenBackground (the flat
         color behind everything) and windowSplashScreenBrandingImage
         (set to null to suppress the bottom branding strip). We do NOT
         set windowSplashScreenAnimatedIcon or
         windowSplashScreenIconBackgroundColor — setting either of those,
         even to our own dark color, still causes several OEM skins
         (MIUI, OxygenOS, etc.) to draw the manifest icon centered on a
         light "icon card" that ignores the color we ask for. Leaving
         both unset means no icon is drawn on the system splash at all —
         just our flat dark background — which avoids that OEM override
         entirely. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/bgColor</item>
        <item name="android:windowSplashScreenBrandingImage">@null</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/bgColor</item>
    </style>
</resources>
