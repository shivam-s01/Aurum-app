<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ (API 31+) uses the system SplashScreen API, which by
         default shows the launcher icon centered on a WHITE card,
         regardless of what launch_background.xml says. This override
         forces that system splash to use our dark brand color instead,
         and disables the default icon-background "card" so the icon
         isn't wrapped in white. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/bgColor</item>
        <!-- Deliberately NOT setting windowSplashScreenAnimatedIcon.
             When this is set to a plain (non-adaptive) icon, Android draws
             it inside its own rounded/circular mask and fills the padding
             with a light card-like backdrop — this is exactly the white
             square you were seeing, and it happens regardless of
             windowSplashScreenBackground or IconBackgroundColor. Leaving
             it unset means the system splash is just a flat dark
             background with no icon, which combined with the immediate
             splashScreen.remove() in MainActivity.onCreate() means this
             frame is on screen for at most a few ms before our own
             Dart-side _A_ + AURUM animation takes over. -->
        <item name="android:windowSplashScreenIconBackgroundColor">@color/bgColor</item>
        <item name="android:windowSplashScreenBrandingImage">@null</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/bgColor</item>
    </style>
</resources>
